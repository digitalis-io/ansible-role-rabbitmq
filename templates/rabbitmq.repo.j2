##
## Zero dependency Erlang RPM
##

[modern-erlang]
name=modern-erlang-el{{ ansible_distribution_major_version }}
baseurl=https://yum1.rabbitmq.com/erlang/el/{{ ansible_distribution_major_version }}/$basearch
        https://yum2.rabbitmq.com/erlang/el/{{ ansible_distribution_major_version }}/$basearch
repo_gpgcheck=1
enabled=1
gpgkey=https://github.com/rabbitmq/signing-keys/releases/download/3.0/cloudsmith.rabbitmq-erlang.E495BB49CC4BBE5B.key
gpgcheck=1
sslverify=1
sslcacert=/etc/pki/tls/certs/ca-bundle.crt
metadata_expire=300
pkg_gpgcheck=1
autorefresh=1
type=rpm-md

[modern-erlang-noarch]
name=modern-erlang-el{{ ansible_distribution_major_version }}-noarch
baseurl=https://yum1.rabbitmq.com/erlang/el/{{ ansible_distribution_major_version }}/noarch
        https://yum2.rabbitmq.com/erlang/el/{{ ansible_distribution_major_version }}/noarch
repo_gpgcheck=1
enabled=1
gpgkey=https://github.com/rabbitmq/signing-keys/releases/download/3.0/cloudsmith.rabbitmq-erlang.E495BB49CC4BBE5B.key
       https://github.com/rabbitmq/signing-keys/releases/download/3.0/rabbitmq-release-signing-key.asc
gpgcheck=1
sslverify=1
sslcacert=/etc/pki/tls/certs/ca-bundle.crt
metadata_expire=300
pkg_gpgcheck=1
autorefresh=1
type=rpm-md

[modern-erlang-source]
name=modern-erlang-el{{ ansible_distribution_major_version }}-source
baseurl=https://yum1.rabbitmq.com/erlang/el/{{ ansible_distribution_major_version }}/SRPMS
        https://yum2.rabbitmq.com/erlang/el/{{ ansible_distribution_major_version }}/SRPMS
repo_gpgcheck=1
enabled=1
gpgkey=https://github.com/rabbitmq/signing-keys/releases/download/3.0/cloudsmith.rabbitmq-erlang.E495BB49CC4BBE5B.key
       https://github.com/rabbitmq/signing-keys/releases/download/3.0/rabbitmq-release-signing-key.asc
gpgcheck=1
sslverify=1
sslcacert=/etc/pki/tls/certs/ca-bundle.crt
metadata_expire=300
pkg_gpgcheck=1
autorefresh=1


